{
  "_comment": "Ported from macolima/config/claude-settings.json. Restricts Claude Code's Bash/Read tools ONLY. Interactive zsh is unrestricted — use it to pip/uv/npm install, clone, push, etc. during planning, then hand off to Claude with this permission profile in force. Paths adapted for root-in-container (rootless Docker userns=host).",
  "sandbox": {
    "_comment": "Disabled: Claude Code's bwrap sandbox needs unprivileged user namespaces, which our seccomp filter blocks. The container itself is the security boundary (cap_drop ALL + seccomp + internal network + Squid allowlist). Sub-blocks preserved inert so the file is portable.",
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "/root/.ssh/**",
        "/home/agent/.ssh/**",
        "**/.env",
        "**/.env.*",
        "**/credentials",
        "**/*secret*",
        "**/*.pem",
        "**/*.key"
      ]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "download.pytorch.org",
        "api.anthropic.com",
        "statsig.anthropic.com"
      ]
    }
  },
  "permissions": {
    "_comment": "Plan interactively (you drive the shell, installs dependencies). Execute autonomously (tight denies, Anthropic-only egress through Squid). acceptEdits lets Claude freely edit code but still prompts for Bash not on the allow list.",
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(uv run:*)",
      "Bash(make:*)",
      "Bash(jq:*)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(socat:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(netcat:*)",
      "Bash(telnet:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(sftp:*)",
      "Bash(rsync:*)",
      "Bash(git push:*)",
      "Bash(git clone:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(gh:*)",
      "Bash(glab:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npx:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(python -m pip install:*)",
      "Bash(uv add:*)",
      "Bash(uv pip install:*)",
      "Bash(uv tool install:*)",
      "Bash(uvx:*)",
      "Bash(pipx:*)",
      "Bash(cargo install:*)",
      "Bash(go install:*)",
      "Bash(go get:*)",
      "Bash(bash -c:*)",
      "Bash(sh -c:*)",
      "Bash(zsh -c:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(node -e:*)",
      "Bash(perl -e:*)",
      "Bash(eval:*)",
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(docker:*)",
      "Bash(sudo:*)",
      "Bash(mount:*)",
      "Bash(umount:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.credentials*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)"
    ]
  }
}
