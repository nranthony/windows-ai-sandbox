        "listxattr", "llistxattr", "flistxattr",
        "madvise", "membarrier", "memfd_create",
        "mincore", "mkdir", "mkdirat", "mknod", "mknodat", "mlock", "mlock2",
        "mmap", "mprotect", "mremap", "msync", "munlock", "munmap",
        "nanosleep", "newfstatat",
        "open", "openat", "openat2",
        "pause", "pidfd_open", "pidfd_send_signal", "pidfd_getfd", "pipe", "pipe2",
        "poll", "ppoll", "prctl",
