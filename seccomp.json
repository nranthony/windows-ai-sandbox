        "sync", "sync_file_range", "syncfs",
        "sysinfo",
        "tee", "tgkill", "timer_create", "timer_delete",
        "timer_getoverrun", "timer_gettime", "timer_settime",
        "timerfd_create", "timerfd_gettime", "timerfd_settime",
