        "vfork", "vmsplice",
        "wait4", "waitid",
        "write", "writev"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "clone — allow but block CLONE_NEWUSER to prevent user-namespace escape",
      "names": ["clone"],
      "action": "SCMP_ACT_ALLOW",
      "args": [
        { "index": 0, "value": 2114060288, "op": "SCMP_CMP_MASKED_EQ" }
      ]
    },
    {
      "_comment": "clone3 — return ENOSYS so glibc falls back to clone (which IS filtered via the CLONE_NEWUSER mask above). seccomp cannot inspect clone3's struct-pointer args, so we refuse it.",
      "names": ["clone3"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 38
    },
    {
      "_comment": "Allow bind/connect/accept for networking",
      "names": ["accept", "accept4", "bind", "connect"],
      "action": "SCMP_ACT_ALLOW"
    }
  ],

  "_blocked_dangerous_syscalls_explanation": {
